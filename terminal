# ===============================
# Ubuntu Commands (Section 3)
# ===============================

# uname — System Info
uname        # show OS name
uname -a     # print all system info (machine name, kernel, version, etc.)
uname -n     # show node hostname

# cal / date — Date & Calendar
cal              # display current year calendar
cal 5 2004       # display calendar for a specific month/year
sudo apt install ncal   # install cal (newer Ubuntu versions)
date             # print current system date and time

# man — Manual Pages
man <command>        # open full manual (e.g. man mv)
man -f <command>     # show short description
man -k <keyword>     # search commands by keyword

# help / --help
<command> --help     # show short usage description
<command> -h         # same (not always supported)

# pwd — Print Working Directory
pwd                 # show current directory path

# whoami — Current User
whoami              # display current logged-in username

# cd — Change Directory
cd /                # navigate to root
cd                  # go to home directory
cd ~                # go to home directory
cd ..               # go up one level
cd -                # go to previous directory
cd /var/www         # navigate to a specific path
cd ~/Desktop        # navigate to Desktop

# ls — List Files
ls                          # list files in current directory
ls ~                        # list home directory files
ls /home/user1/dir1         # list files in a specific path
ls -a                       # include hidden files
ls -l                       # long listing
ls -F                       # append / to directories
ls -ld <dirname>            # info about specific directory
ls -R                       # recursive listing
ls -lh                      # human-readable sizes
ls -d                       # info about selected file/dir

# df / du — Disk Usage
df              # show free disk space
df -h           # human-readable
du <dir>        # space used by directory
du -sh          # human-readable total size

# mkdir / touch — Create Files & Folders
mkdir folder_name                         # create folder
mkdir -p folder1/folder2/folder3         # create nested folders
touch filename.txt                        # create file

# cat — View / Create Files
cat file-name                     # display contents
cat file1 file2                   # view multiple files
cat > file-name                   # create file (Ctrl+D to save)
cat -n file-name                  # show with line numbers
cat file1 > file2                 # overwrite file2
cat file1 >> file2                # append to file2
cat file1 file2 file3 > file4     # merge files

# cp — Copy Files/Directories
cp source target          # copy file
cp -i source target       # prompt before overwrite
cp -r source target       # copy directory

# mv — Move / Rename
mv source target          # move or rename
mv -i source target       # prompt before overwrite

# rm / rmdir — Remove Files/Directories
rm file_name              # delete file
rmdir directory_name      # remove empty directory
rm -r directory_name      # remove non-empty directory
rm -p                     # remove directory and ancestors
rm -i                     # prompt before deleting

# head / tail — View File Lines
head filename                 # first 10 lines
head -n <num> filename        # first N lines
tail filename                 # last 10 lines
tail -n <num> filename        # last N lines
tail -n+<num> filename        # from line N
# إنشاء مجلد باسم AhmedAyman
mkdir AhmedAyman

# الدخول للمجلد
cd AhmedAyman

# إنشاء ملف داخله
touch AhmedAyman.txt

# إنشاء كذا ملف
